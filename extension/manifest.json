{
  "manifest_version": 3,
  "name": "Clinical Ally",
  "version": "0.1.0",
  "permissions": [
    "storage"
  ],
  "description": "AI co-pilot sidebar for OpenEMR \u2014 runs entirely on localhost",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "client.js",
        "autofiller.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "panel.html",
        "panel.css",
        "client.js",
        "context-manager.js",
        "image-manager.js",
        "panel.js"
      ],
      "matches": [
        "*://localhost/*",
        "*://localhost:8080/*",
        "*://localhost:8443/*",
        "*://localhost:8000/*"
      ]
    }
  ],
  "host_permissions": [
    "*://localhost/*",
    "*://localhost:8080/*",
    "*://localhost:8000/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "clinical-ally@localhost"
    }
  }
}
